{
    "name": "portphp/pdo",
    "description": "PDO adapter for Port",
    "license": "MIT",
    "homepage": "https://github.com/portphp",
    "authors": [
        {
            "name": "David de Boer",
            "email": "david@ddeboer.nl"
        },
        {
            "name": "Markus Bachmann",
            "email": "markus.bachmann@bachi.biz"
        },
        {
            "name": "Community contributors",
            "homepage": "https://github.com/portphp/pdo/graphs/contributors"
        }
    ],
    "support": {
        "issues": "https://github.com/portphp/portphp/issues",
        "source": "https://github.com/portphp/pdo",
        "docs": "https://portphp.readthedocs.io"
    },
    "require": {
        "php": "^8.2",
        "ext-pdo": "*",
        "portphp/portphp": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Port\\Pdo\\": "src/"
        }
    },
    "require-dev": {
        "ext-pdo_sqlite": "*",
        "phpunit/phpunit": "^9.6"
    },
    "autoload-dev": {
        "psr-4": {
            "Port\\Pdo\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "2.0.x-dev"
        }
    }
}
